    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nimport sys\r\nsys.path.append('C:\\Program Files (x86)\\IronPython 2.7\\Lib')\r\n\r\nimport System\r\nfrom System.Collections.Generic import *\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\nclr.AddReference(\"RevitServices\")\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager \r\nfrom RevitServices.Transactions import TransactionManager \r\n\r\nclr.AddReference(\"RevitAPI\")\r\nclr.AddReference(\"RevitAPIUI\")\r\n\r\nimport Autodesk \r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nuiapp = DocumentManager.Instance.CurrentUIApplication \r\napp = uiapp.Application \r\nuidoc = uiapp.ActiveUIDocument\r\n\r\ndef tolist(obj1):\r\n\tif isinstance(obj1,(list, tuple, set)): return obj1\r\n\telse: return [obj1]\r\n\r\n#Preparing input from dynamo to revit\r\nele = UnwrapElement(IN[0])\r\n\r\n#Do some action in a Transaction\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\"\"\"\r\ndetailLine = FilteredElementCollector(doc).OfClass(CurveElement).FirstElement()\r\ncurve = detailLine.Location.Curve\r\n\r\nwallTypes = FilteredElementCollector(doc).OfClass(WallType).ToElements()\r\nfor wallType in wallTypes:\r\n    if wallType.LookupParameter(\"Type Name\").AsString() == \"CMU Wall\":\r\n        wallTypeID = wallType.Id\r\n        break\r\n\r\nlevels = FilteredElementCollector(doc).OfClass(Level).ToElements()\r\nfor level in levels:\r\n    if level.Name == \"Level 0\":\r\n        levelID = level.Id\r\n        break\r\n\r\ntheWall = Wall.Create(doc, curve, wallTypeID, levelID, 2500/304.8, 0, False, False)\r\n\r\nmidPoint = curve.Evaluate(0.5, True)\r\n\r\ndoorTypes = FilteredElementCollector(doc).OfCategory(BuiltInCategory.OST_Doors).WhereElementIsElementType().ToElements()\r\nfor doorType in doorTypes:\r\n    if doorType.LookupParameter(\"Type Name\").AsString() == \"1810x2110mm\":\r\n        TypeOfDoor = doorType \r\n\r\ndoor = doc.Create.NewFamilyInstance(midPoint, TypeOfDoor, theWall, StructuralType.NonStructural)\r\n\r\n\r\nsp = XYZ()\r\nep = XYZ(10,0,0)\r\nline = Line.CreateBound(sp, ep)\r\n\r\ntypecabletray_types=FilteredElementCollector(doc).OfClass(CableTrayType).ToElements()\r\ncabletray_type=cabletray_types[0]\r\n#get level\r\nlevels=FilteredElementCollector(doc).OfClass(Level).ToElements()\r\nfor level in levels:    \r\n    if level.Name==\"Level 2\":        \r\n        levelid=level        \r\n        break\r\n#get detail line\r\ndetail_lines=FilteredElementCollector(doc).OfClass(CurveElement).ToElements()\r\ndetail_line=detail_lines[0]\r\ndl=detail_line.GeometryCurve\r\nstartpoint=dl.GetEndPoint(0)\r\nendpoint=dl.GetEndPoint(1)\r\ncabletray=CableTray.Create(doc,cabletray_type.Id,startpoint,endpoint,level.Id)\r\n\"\"\"\r\n\r\n\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = \"5\\' 12\\\"\"",
