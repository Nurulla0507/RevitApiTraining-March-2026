      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nimport sys\r\nsys.path.append('C:\\Program Files (x86)\\IronPython 2.7\\Lib')\r\n\r\nimport System\r\nfrom System.Collections.Generic import *\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\nclr.AddReference(\"RevitServices\")\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager \r\nfrom RevitServices.Transactions import TransactionManager \r\n\r\nclr.AddReference(\"RevitAPI\")\r\nclr.AddReference(\"RevitAPIUI\")\r\n\r\nimport Autodesk \r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nuiapp = DocumentManager.Instance.CurrentUIApplication \r\napp = uiapp.Application \r\nuidoc = uiapp.ActiveUIDocument\r\n\r\ndef tolist(obj1):\r\n\tif isinstance(obj1,(list, tuple, set)): return obj1\r\n\telse: return [obj1]\r\n\r\n#Preparing input from dynamo to revit\r\ndl = UnwrapElement(IN[0])\r\nduct = UnwrapElement(IN[1])\r\n\r\n#Do some action in a Transaction\r\n\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n\"\"\"\r\nDelete elements\r\nwalls = FilteredElementCollector(doc).OfClass(Wall).ToElements()\r\n\r\nfor wall in walls:\r\n    doc.Delete(wall.Id)\r\n\"\"\"\r\n\r\n\r\nfurnitures = FilteredElementCollector(doc).OfCategory(BuiltInCategory.OST_Furniture).WhereElementIsNotElementType().ToElements()\r\n\r\nfor furn in furnitures:\r\n    if furn.LookupParameter(\"Mark\").AsString() == \"Test\":\r\n        ele = furn\r\n        break\r\n\r\n\"\"\"\r\npublic static ICollection<ElementId> CopyElement(\r\n    Document document,\r\n    ElementId elementToCopy,\r\n    XYZ translation\r\n)\"\"\"\r\n\r\ntrans = XYZ(-3000/304.8, 7000/304.8, 0)\r\n\r\nxValues = range(3000,9001,3000)\r\n\r\nfor x in xValues:\r\n    trans = XYZ(x/304.8, 0, 0) \r\n    #ElementTransformUtils.CopyElement(doc, ele.Id, trans)\r\n\r\n\"\"\"\r\npublic static void MoveElement(\r\n    Document document,\r\n    ElementId elementToMove,\r\n    XYZ translation\r\n)\"\"\"\r\n\r\n\r\ntrans = XYZ(5000/304.8, 5000/304.8, 0)\r\n#ElementTransformUtils.MoveElement(doc, ele.Id, trans)\r\n\r\n\r\n#cp = dl.Location.Curve.Center\r\n#ele.Location.Point = cp\r\n\r\n\r\n#newCurve = dl.Location.Curve\r\n#duct.Location.Curve = newCurve\r\n\r\n\r\nval = ele.Pinned\r\n#ele.Pinned = True\r\n\r\n\"\"\"\r\npublic static void RotateElement(\r\n    Document document,\r\n    ElementId elementToRotate,\r\n    Line axis,\r\n    double angle\r\n)\"\"\"\r\n\r\n\r\ncp = ele.Location.Point\r\ntp = XYZ(cp.X, cp.Y, cp.Z+10)\r\n\r\naxis = Line.CreateBound(cp, tp)\r\n\r\n#ElementTransformUtils.RotateElement(doc, ele.Id, axis, 0.523599)\r\n\r\n\r\n\"\"\"\r\npublic static void MirrorElement(\r\n    Document document,\r\n    ElementId elementToMirror,\r\n    Plane plane\r\n)\r\npublic static Plane CreateByNormalAndOrigin(\r\n    XYZ normal,\r\n    XYZ origin\r\n)\r\n\"\"\"\r\n\r\n\r\nxAxis = XYZ(1,0,0)\r\nplane = Plane.CreateByNormalAndOrigin(xAxis, dl.Location.Curve.GetEndPoint(0))\r\n\r\n\r\nElementTransformUtils.MirrorElement(doc, ele.Id, plane)\r\n\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = plane",
