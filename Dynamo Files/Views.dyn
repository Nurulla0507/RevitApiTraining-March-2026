    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nimport sys\r\nsys.path.append('C:\\Program Files (x86)\\IronPython 2.7\\Lib')\r\n\r\nimport System\r\nfrom System.Collections.Generic import *\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\nclr.AddReference(\"RevitServices\")\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager \r\nfrom RevitServices.Transactions import TransactionManager \r\n\r\nclr.AddReference(\"RevitAPI\")\r\nclr.AddReference(\"RevitAPIUI\")\r\n\r\nimport Autodesk \r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nuiapp = DocumentManager.Instance.CurrentUIApplication \r\napp = uiapp.Application \r\nuidoc = uiapp.ActiveUIDocument\r\n\r\ndef tolist(obj1):\r\n\tif isinstance(obj1,(list, tuple, set)): return obj1\r\n\telse: return [obj1]\r\n\r\n#element = UnwrapElement(IN[0])\r\ndl = tolist(UnwrapElement(IN[0]))\r\nfr = UnwrapElement(IN[1])\r\n\r\n#Do some action in a Transaction\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\"\"\"\r\npublic static Wall Create(\r\n    Document document,\r\n    IList<Curve> profile,\r\n    ElementId wallTypeId,\r\n    ElementId levelId,\r\n    bool structural\r\n)\r\n\"\"\"\r\nwalltyp = FilteredElementCollector(doc).OfClass(WallType).ToElements()\r\n\r\nlevel = FilteredElementCollector(doc).OfClass(Level).ToElements()\r\n\r\n#detailLine = FilteredElementCollector(doc).OfClass(CurveElement)#.ToElements()\r\n\r\nfor lvl in level:\r\n    if lvl.Name == \"Level 0\":\r\n        lvlid = lvl.Id\r\n        break\r\n\r\n\r\nfor id in walltyp:\r\n    if id.LookupParameter(\"Type Name\").AsString() == \"Wall-Ret_300Con\":\r\n        walltypid = id.Id\r\n        break \r\n\r\nfor crve in dl:\r\n    curve = crve.Location.Curve\r\n    #wall = Wall.Create(doc, curve, lvlid, True)\r\n\r\n\"\"\"\r\npublic static Wall Create(\r\n    Document document,\r\n    IList<Curve> profile,\r\n    ElementId wallTypeId,\r\n    ElementId levelId,\r\n    bool structural\r\n)\"\"\"\r\n\r\n\r\ncl = List[Curve]()\r\nfor i in list(fr.GetBoundaries()):\r\n    for j in i:\r\n        cl.Add(j)\r\n\r\n\r\nnewProfileWall = Wall.Create(doc, cl , walltyp[0].Id, lvlid, True)\r\n\r\n\r\n\r\n\"\"\"\r\nfor crve in dl:\r\n    curve = crve.Location.Curve\r\n    curveList.append(curve)\r\n#ccurveList = List[Curve](curveList)\r\n\r\n  \r\n\r\n#curve = dl.Location.Curve\r\n\r\ni = 0\r\n\r\nwhile i <= (len(curveList)-1):\r\n    wall = Wall.Create(doc, curveList[i], lvlid, False)\r\n    i += 1\r\n\r\n#wall = Wall.Create(doc, curve, walltypid, lvlid, True)\r\n\"\"\"\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = fr.GetBoundaries()",
