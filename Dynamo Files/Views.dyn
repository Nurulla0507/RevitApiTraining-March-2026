    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Dynamo Python script (Revit API)\r\n\r\nimport clr\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nfrom collections import defaultdict\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# Collect all views\r\nviews = FilteredElementCollector(doc) \\\r\n    .OfCategory(BuiltInCategory.OST_Views) \\\r\n    .WhereElementIsNotElementType() \\\r\n    .ToElements()\r\n\r\n# OPTIONAL but recommended: remove templates\r\nviews = [v for v in views if not v.IsTemplate]\r\n\r\n# Group views by ViewType\r\ngrouped_views = defaultdict(list)\r\n\r\nfor v in views:\r\n    grouped_views[v.ViewType].append(v.Name)\r\n\r\n# Sort names inside each group\r\nfor vt in grouped_views:\r\n    grouped_views[vt].sort()\r\n\r\n# Convert to Dynamo-friendly output (lists instead of dict)\r\nviewTypes = []\r\nnamesGrouped = []\r\n\r\nfor vt in sorted(grouped_views.keys(), key=lambda x: str(x)):\r\n    viewTypes.append(str(vt))\r\n    namesGrouped.append(grouped_views[vt])\r\n\r\nOUT = viewTypes, namesGrouped",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "04f5349d1ff54af3bccfd405c7c8bdcb",
      "NodeType": "PythonScriptNode",
